# .env.example
#
# 사용법:
#   이 파일을 .env 로 복사한 뒤 실제 값으로 채워 넣으세요.
#   .env 는 .gitignore 에 등록되어 있으므로 git 에 커밋되지 않습니다.
#
# 우선순위: config/app_config.yaml > 환경변수 > 코드 기본값
# app_config.yaml 에 값이 있으면 아래 환경변수는 사용되지 않습니다.

# ── MCP 서버 설정 ──────────────────────────────────────────────────────────
# chatRTD CLI 가 연결할 MCP 서버 주소
MCP_BASE_URL=http://localhost:8000/mcp

# ── LLM 설정 (OpenAI 호환 API) ────────────────────────────────────────────
# API 엔드포인트 (Groq, OpenAI, 사내 프록시 등)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# API 인증 키
OPENAI_API_KEY=
# 사용할 모델 ID
OPENAI_MODEL=openai/gpt-oss-120b
# 프로바이더 식별자 (openai_compatible 등)
OPENAI_PROVIDER=openai_compatible

# ── 사내/내부 LLM 별도 설정 (선택, OPENAI_* 보다 우선순위 높음) ───────────
INTERNAL_LLM_BASE_URL=
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=
INTERNAL_LLM_PROVIDER=

# ── Chrome URL 조회 (fetch_url_chrome 스킬) ────────────────────────────────
# Playwright 설치 후: playwright install chrome
# 자동화 전용 Chrome 프로필 (일반 Default 프로필과 분리 권장)
CHROME_USER_DATA_DIR=
# Playwright browser channel (기본 chrome)
CHROME_CHANNEL=chrome

# ── Oracle DB (query_oracle_db 스킬) ───────────────────────────────────────
# 여러 DB를 .env 에 별칭(prefix)으로 등록합니다.
# 패턴: ORACLE_DB_{별칭}_USER / ORACLE_DB_{별칭}_PASSWORD / ORACLE_DB_{별칭}_TNS
# 스킬 호출 시 db 인자로 별칭을 지정합니다. (예: db=prod)

# db 인자 생략 시 사용할 기본 DB 별칭
ORACLE_DEFAULT_DB=prod

# tnsnames.ora 가 있는 폴더 경로 (TNS alias 사용 시, 모든 DB 공통)
# 예: C:\oracle\network\admin
ORACLE_TNS_ADMIN=

# Oracle Instant Client 경로 (Thin 모드에서 TNS alias 미지원 시 Thick 모드용, 선택)
ORACLE_CLIENT_LIB_DIR=

# 조회 결과 최대 반환 행 수 (모든 DB 공통 기본값, 기본 1000)
ORACLE_MAX_ROWS=1000

# ── prod DB ───────────────────────────────────────────────────────────────
ORACLE_DB_PROD_USER=
ORACLE_DB_PROD_PASSWORD=
# TNS alias (예: ORCL_PROD) 또는 Easy Connect (host:port/service_name)
ORACLE_DB_PROD_TNS=

# ── dev DB ──────────────────────────────────────────────────────────────────
ORACLE_DB_DEV_USER=
ORACLE_DB_DEV_PASSWORD=
ORACLE_DB_DEV_TNS=

# ── 레거시 단일 DB (별칭 default 로 동작) ───────────────────────────────────
# 다중 DB 설정과 병행 가능. 아래 3개만 쓰면 db 인자 없이 default 로 접속합니다.
# ORACLE_USER=
# ORACLE_PASSWORD=
# ORACLE_TNS=

{
  "model": {
    "name": "gemini-2.5-flash"
  },
  "ui": {
    "theme": "chatRTD",
    "hideBanner": false,
    "showUserIdentity": false,
    "customThemes": {
      "chatRTD": {
        "name": "chatRTD",
        "type": "custom",
        "Background": "#1a1a1f",
        "Foreground": "#e0e0e0",
        "LightBlue": "#5c9cf5",
        "AccentBlue": "#5c9cf5",
        "AccentPurple": "#9d7cd8",
        "AccentCyan": "#56b6c2",
        "AccentGreen": "#7fd99a",
        "AccentYellow": "#fab283",
        "AccentRed": "#f07178",
        "Comment": "#6a6a6a",
        "Gray": "#8a8a8a"
      }
    }
  },
  "mcpServers": {
    "win-automation": {
      "httpUrl": "http://localhost:8000/mcp",
      "trust": true,
      "timeout": 600000
    }
  },
  "security": {
    "auth": {
      "selectedType": "gemini-api-key"
    }
  }
}

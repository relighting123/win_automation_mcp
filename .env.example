# 로컬 환경 변수 (복사 후 사용)
# cp .env.example .env
#
# app_config.yaml에 값이 있으면 해당 값이 우선 적용됩니다.
# api_key 등 민감 정보는 .env에 두는 것을 권장합니다.

# MCP 서버 URL
MCP_BASE_URL=http://localhost:8000/mcp

# LLM (OpenAI 호환 API)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_PROVIDER=openai_compatible

# 내부 LLM 별칭 (OPENAI_* 와 동일 용도, 우선순위가 더 높음)
INTERNAL_LLM_BASE_URL=
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=
INTERNAL_LLM_PROVIDER=

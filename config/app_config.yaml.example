# Application Configuration for Windows Automation
# FastMCP + pywinauto 기반 윈도우 자동화 설정
#
# 사용법:
#   이 파일을 config/app_config.yaml 로 복사한 뒤
#   실제 값으로 채워 넣으세요.
#   config/app_config.yaml 은 .gitignore 에 등록되어 있으므로
#   git 에 커밋되지 않습니다.

application:
  # pywinauto가 붙을 타겟 애플리케이션 exe 경로
  connect_path: "C:\\Program Files\\YourApp\\app.exe"
  # file_path 미지정 시 launch_application은 connect_path exe를 실행합니다.
  # .rul 등 데이터 파일은 스킬 launch_application args.file_path로 지정하세요.
  # 애플리케이션 이름 (프로세스 실행 중인지 등을 판단하는 용도)
  process_name: "app.exe"
  # 윈도우 제목 정규식 (연결 시 사용)
  # window_title_re: ".*YourApp.*"
  # pywinauto backend 설정 (uia 권장)
  backend: "uia"
  # 애플리케이션 시작 후 초기화 대기 시간 (초)
  startup_timeout: 30
  # 자동화 속도 설정 (fast, normal)
  automation_speed: "fast"

timeouts:
  # 기본 요소 대기 시간 (초)
  default_wait: 10
  # 긴 작업 대기 시간 (초)
  long_wait: 60
  # 짧은 작업 대기 시간 (초)
  short_wait: 3
  # 재시도 간격 (초)
  retry_interval: 0.1
  # UI 조작 후 대기 시간 (초)
  ui_delay: 0.1
  # 포커스 설정 후 대기 시간 (초)
  after_focus_delay: 0.1

retry:
  # 기본 재시도 횟수
  default_attempts: 3
  # 연결 재시도 횟수
  connection_attempts: 5

logging:
  # 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
  level: "INFO"
  # 로그 파일 경로
  file_path: "logs/automation.log"
  # 로그 파일 최대 크기 (MB)
  max_size_mb: 10
  # 로그 파일 보관 개수
  backup_count: 5

server:
  # FastMCP 서버 이름
  name: "Windows Automation MCP Server"
  # 서버 버전
  version: "1.0.0"

mcp:
  # FastMCP 서버 HTTP endpoint
  base_url: "http://localhost:8001/mcp"
  # 추가 MCP 서버 (stdio/HTTP, 선택)
  extra_servers: []

automation:
  # 자동화 모드 설정 (auto: 자유 계획 및 개입, semi: 순차 실행 + 상황 개입, manual: 순차 실행 전용)
  mode: "manual"

file_access:
  # 소스 파일 검색/치환(find_text_in_file 등) 허용 경로
  allow_workspace: true
  allowed_paths:
    - "D:\\개발\\폴더"
    # - "C:\\Rules"

reports:
  # 일일/주간 업무 보고서 저장 경로 (워크스페이스 기준 상대경로 가능)
  daily_dir: "reports/daily"
  weekly_dir: "reports/weekly"
  config_file: "skills/daily_work_summary/report_config.yaml"

llm:
  # 기본 provider: OpenAI 호환 API
  provider: "openai_compatible"
  # API base URL (예: https://api.openai.com/v1, https://api.groq.com/openai/v1 등)
  base_url: "https://api.groq.com/openai/v1"
  # 사용할 모델 이름
  model: "openai/gpt-oss-120b"
  # API 키 (또는 .env 의 INTERNAL_LLM_API_KEY / OPENAI_API_KEY 환경변수 사용)
  api_key: ""

  profiles:
    # 단순 실행/파라미터 추출: 경량 모델
    execution:
      provider: "openai_compatible"
      base_url: "https://api.groq.com/openai/v1"
      model: "openai/gpt-oss-120b"
      api_key: ""
    # 계획 수립
    planning:
      provider: "openai_compatible"
      base_url: "https://api.groq.com/openai/v1"
      model: "openai/gpt-oss-120b"
      api_key: ""
    # 상황/데이터 분석
    analysis:
      provider: "openai_compatible"
      base_url: "https://api.groq.com/openai/v1"
      model: "openai/gpt-oss-120b"
      api_key: ""
    # 최종 리포트 생성
    reporting:
      provider: "openai_compatible"
      base_url: "https://api.groq.com/openai/v1"
      model: "openai/gpt-oss-120b"
      api_key: ""

# 스킬 정의 (레거시 단일 파일 형식)
#
# 사용 방법:
#   cp config/skills.yaml.example config/skills.yaml
#   이후 회사/로컬 환경에 맞게 값을 수정하세요.
#
# 신규 스킬은 skills/<skill_name>/skill.yaml 형식을 권장합니다.

skills:
  demo_app_mgmt_tools:
    description: "app_mgmt_tool 계열 도구 사용 예시"
    tools:
      - tool: launch_application
        args:
          wait_for_window: true

      - tool: get_connection_status

      - tool: connect_to_application
        args:
          window_title_re: ".*Notepad\\+\\+.*"

      - tool: restart_application

      - tool: generate_locators
        args:
          window_type: "active_window"

      - tool: close_application
        args:
          force: false

      - tool: close_window
        args:
          child_window_title: "Find"
          window_target: child
          child_window_match_mode: contains

  demo_app_control_tools:
    description: "app_control_tool 계열 도구 사용 예시"
    tools:
      - tool: launch_application

      - tool: find_app_by_ocr
        args:
          keyword: "{keyword}"
          language: "kor+eng"
          timeout: 2.0
          match_mode: "contains"

      - tool: click_app_by_attr
        args:
          title: "Save"
          title_match_mode: "contains"
          case_sensitive: false
          button: "left"
          clicks: 1

      - tool: type_app_text
        args:
          text: "hello {username}"
          interval: 0.03

      - tool: press_app_shortcut
        args:
          shortcut: "ctrl+s"

      - tool: click_at_focus
        args:
          button: right
          clicks: 1
          require_app_focus: true
          offset_x: 0
          offset_y: 0

      - tool: click_app_position
        args:
          x: 640
          y: 360
          button: "left"
          clicks: 1

      - tool: click_app_by_keyword
        args:
          keyword: "Submit"
          element_type: "button"
          match_mode: "contains"
          case_sensitive: false
          button: "left"
          clicks: 1

      - tool: click_app_by_attr
        args:
          auto_id: "SaveBtn_1"
          control_type: "Button"
          title: "Save"
          title_match_mode: "exact"
          window_target: "child"
          child_window_title: "Document"
          child_window_match_mode: "contains"
          button: "left"
          double: false
          timeout: 2.0
          draw_outline: true
          outline_colour: "red"

      - tool: highlight_app_by_attr
        args:
          title: "Cancel"
          control_type: "Button"
          timeout: 2.0
          outline_colour: "green"

      - tool: get_app_coords_by_attr
        args:
          auto_id: "MainInputArea"
          control_type: "Edit"
          timeout: 2.0

      - tool: wait
        args:
          seconds: 1.0

  # demo_full_flow_tools, demo_mixed_args, query_oracle_db 등은 skills/ 폴더에 정의됩니다.
  # skills/<name>/skill.yaml 이 있으면 자동 등록됩니다.

  query_oracle_db:
    description: "Oracle DB에서 SELECT 쿼리를 실행하고 결과를 반환"

  analyze_copied_table:
    description: "Ctrl+C로 복사된 데이터를 DataFrame으로 변환해 분석 리포트에 반영"
    tools:
      - tool: press_app_shortcut
        args:
          shortcut: "ctrl+c"
      - tool: read_clipboard_as_dataframe
        args:
          delimiter: null
          header: true
          max_preview_rows: 20

  open_guide_based_rule:
    description: "사용자 요청에 따라 가이드 문서를 참조하여 적절한 .rul 파일을 선택하고 실행"
    tools:
      - tool: launch_application
        args:
          # executable_path / file_path / path 모두 지원
          file_path: { mode: "ai", value: "C:\\Path\\To\\Your\\default.rul" }
      - tool: wait
        args:
          seconds: 2.0

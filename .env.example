# .env.example
#
# 사용법:
#   이 파일을 .env 로 복사한 뒤 실제 값으로 채워 넣으세요.
#   .env 는 .gitignore 에 등록되어 있으므로 git 에 커밋되지 않습니다.
#
# 우선순위: config/app_config.yaml > 환경변수 > 코드 기본값
# app_config.yaml 에 값이 있으면 아래 환경변수는 사용되지 않습니다.

# ── LLM 설정 ──────────────────────────────────────────────────────────────
# OpenAI 호환 API 키
OPENAI_API_KEY=your_api_key_here

# API base URL (기본: https://api.groq.com/openai/v1)
OPENAI_BASE_URL=https://api.your-provider.com/v1

# 사용할 모델 이름
OPENAI_MODEL=your-model-name

# provider 이름 (기본: openai_compatible)
# OPENAI_PROVIDER=openai_compatible

# ── 사내/내부 LLM 별도 설정 (선택) ────────────────────────────────────────
# INTERNAL_LLM_API_KEY=your_internal_api_key_here
# INTERNAL_LLM_BASE_URL=https://internal.api.company.com/v1
# INTERNAL_LLM_MODEL=internal-model-name
# INTERNAL_LLM_PROVIDER=openai_compatible

# ── MCP 서버 설정 ──────────────────────────────────────────────────────────
# MCP_BASE_URL=http://localhost:8000/mcp

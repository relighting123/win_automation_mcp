# Oracle DB 연결 설정
#
# 사용법:
#   이 파일을 config/oracle_databases.yaml 로 복사한 뒤 실제 값으로 채우세요.
#   config/oracle_databases.yaml 은 .gitignore 에 등록되어 git 에 커밋되지 않습니다.
#
# 각 DB 항목 상단에 alias 를 두고, user / password / host 등을 아래에 정의합니다.
# 스킬·도구 호출 시 db 인자로 alias 를 지정합니다. (예: db=prd)

# db 인자 생략 시 사용할 기본 별칭
default_db: prd

# 모든 DB에 공통 적용 (개별 항목에서 덮어쓰기 가능)
tns_admin: ""
client_lib_dir: ""
max_rows: 1000

databases:
  - alias: prd
    user: prod_user
    password: secret
    # 방법 1: host + port + service_name (Easy Connect)
    host: db-prod.example.com
    port: 1521
    service_name: ORCL_PROD
    # 방법 2: tnsnames.ora 의 TNS alias (host 대신 사용 가능)
    # tns: ORCL_PROD

  - alias: dev
    user: dev_user
    password: secret
    host: db-dev.example.com
    port: 1521
    service_name: ORCL_DEV

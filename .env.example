# .env.example
#
# 사용법:
#   이 파일을 .env 로 복사한 뒤 실제 값으로 채워 넣으세요.
#   .env 는 .gitignore 에 등록되어 있으므로 git 에 커밋되지 않습니다.
#
# 우선순위: config/app_config.yaml > 환경변수 > 코드 기본값
# app_config.yaml 에 값이 있으면 아래 환경변수는 사용되지 않습니다.

# ── MCP 서버 설정 ──────────────────────────────────────────────────────────
# chatRTD CLI 가 연결할 MCP 서버 주소
MCP_BASE_URL=http://localhost:8000/mcp

# ── LLM 설정 (OpenAI 호환 API) ────────────────────────────────────────────
# API 엔드포인트 (Groq, OpenAI, 사내 프록시 등)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# API 인증 키
OPENAI_API_KEY=
# 사용할 모델 ID
OPENAI_MODEL=openai/gpt-oss-120b
# 프로바이더 식별자 (openai_compatible 등)
OPENAI_PROVIDER=openai_compatible

# ── 사내/내부 LLM 별도 설정 (선택, OPENAI_* 보다 우선순위 높음) ───────────
INTERNAL_LLM_BASE_URL=
INTERNAL_LLM_API_KEY=
INTERNAL_LLM_MODEL=
INTERNAL_LLM_PROVIDER=

# ── Browser MCP (chatRTD 멀티 MCP) ─────────────────────────────────────────
# true 로 설정하면 chatRTD가 @browsermcp/mcp(stdio)를 추가 MCP로 연결합니다.
MCP_BROWSER_MCP_ENABLED=false
# Chrome 확장(Browser MCP) 설치 후 Connect 클릭 필요
# https://chromewebstore.google.com/detail/browser-mcp-automate-your/bjfgambnhccakkhmkepdoekmckoijdlc

# (하위 호환) 예전 Chrome DevTools MCP 플래그 — true 시 Browser MCP로 동일 처리
MCP_CHROME_DEVTOOLS_ENABLED=false

# fetch_url_info / daily_work_summary 웹 수집 시 위 Browser MCP 설정을 활성화하세요.

# ── 업무 보고서 (daily_work_summary / weekly_report) ─────────────────────
# CHATRTD_DAILY_REPORT_DIR=reports/daily
# CHATRTD_WEEKLY_REPORT_DIR=reports/weekly
# CHATRTD_DAILY_REPORT_CONFIG=skills/daily_work_summary/report_config.yaml

# ── Oracle DB (query_oracle_db 스킬) ───────────────────────────────────────
# 권장: config/oracle_databases.yaml (config/oracle_databases.yaml.example 참고)
#
#   default_db: prd
#   databases:
#     - alias: prd
#       user: ...
#       password: ...
#       host: ...
#       port: 1521
#       service_name: ...
#
# 스킬 호출 시 db 인자로 alias 를 지정합니다. (예: db=prd)
#
# 레거시 .env 다중 DB (YAML 미사용 시):
# 패턴: ORACLE_DB_{별칭}_USER / ORACLE_DB_{별칭}_PASSWORD / ORACLE_DB_{별칭}_TNS

# db 인자 생략 시 사용할 기본 DB 별칭
ORACLE_DEFAULT_DB=prd

# tnsnames.ora 가 있는 폴더 경로 (TNS alias 사용 시, 모든 DB 공통)
# 예: C:\oracle\network\admin
ORACLE_TNS_ADMIN=

# Oracle Instant Client 경로 (Thin 모드에서 TNS alias 미지원 시 Thick 모드용, 선택)
ORACLE_CLIENT_LIB_DIR=

# 조회 결과 최대 반환 행 수 (모든 DB 공통 기본값, 기본 1000)
ORACLE_MAX_ROWS=1000

# ── 레거시 .env 다중 DB (YAML 없을 때만 사용) ───────────────────────────────
# ORACLE_DB_PRD_USER=
# ORACLE_DB_PRD_PASSWORD=
# ORACLE_DB_PRD_TNS=

# ORACLE_DB_DEV_USER=
# ORACLE_DB_DEV_PASSWORD=
# ORACLE_DB_DEV_TNS=

# ── 레거시 단일 DB (별칭 default 로 동작) ───────────────────────────────────
# 다중 DB 설정과 병행 가능. 아래 3개만 쓰면 db 인자 없이 default 로 접속합니다.
# ORACLE_USER=
# ORACLE_PASSWORD=
# ORACLE_TNS=
